# Automatic HTTPS for InterviewPad.
#
# Caddy provisions a Let's Encrypt cert for $DOMAIN over the HTTP-01 challenge,
# so ports 80 and 443 must be publicly reachable and the Cloudflare DNS record
# should be "DNS only" (grey cloud). See DEPLOY.md.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	# Interactive terminal WebSocket -> ptyd. handle_path strips /pty so ptyd
	# sees /<padId>.
	handle_path /pty/* {
		reverse_proxy ptyd:8081
	}

	# Everything else -> Rustpad (editor UI + /api/socket collaboration WS).
	reverse_proxy rustpad:3030
}
